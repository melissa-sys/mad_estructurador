  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsIndividuallyAssessedForCreditLossesMember" unitRef="COP" decimals="0">4548979259</ifrs:FinancialAssets>
