  <ifrs:AnalysisOfCreditExposuresUsingExternalCreditGradingSystemExplanatory contextRef="YQTD1C_ClasesActivosFinancierosEje_ConsumerLoansMember">N/A</ifrs:AnalysisOfCreditExposuresUsingExternalCreditGradingSystemExplanatory>
