  <ifrs:AnalysisOfCreditExposuresUsingExternalCreditGradingSystemExplanatory contextRef="YQTD1C_ClasesActivosFinancierosEje_FinancialAssetsMember">N/A</ifrs:AnalysisOfCreditExposuresUsingExternalCreditGradingSystemExplanatory>
