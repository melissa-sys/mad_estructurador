  <ifrs:ExplanationOfFinancialEffectOfContingentLiabilities contextRef="YQTD2C_ClassesOfContingentLiabilitiesAxis_OtherContingentLiabilitiesMember">N/A</ifrs:ExplanationOfFinancialEffectOfContingentLiabilities>
  <ifrs:ExplanationOfFinancialEffectOfContingentLiabilities contextRef="YQTD2C_ClassesOfContingentLiabilitiesAxis_ContingentLiabilitiesMember">N/A</ifrs:ExplanationOfFinancialEffectOfContingentLiabilities>
