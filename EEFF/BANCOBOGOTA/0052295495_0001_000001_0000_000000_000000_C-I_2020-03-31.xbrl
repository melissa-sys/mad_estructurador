  <ifrs:InformationAboutCreditQualityOfNeitherPastDueNorImpairedFinancialAssets contextRef="YQTD1C_CategoriasActivosFinancierosEje_LoansAndReceivablesCategoryMember">N/A</ifrs:InformationAboutCreditQualityOfNeitherPastDueNorImpairedFinancialAssets>
