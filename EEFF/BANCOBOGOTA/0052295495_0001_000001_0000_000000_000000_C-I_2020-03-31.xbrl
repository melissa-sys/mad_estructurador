  <ifrs:ExplanationOfFinancialEffectOfContingentLiabilities contextRef="YQTD1C_ClassesOfContingentLiabilitiesAxis_ContingentLiabilitiesMember">N/A</ifrs:ExplanationOfFinancialEffectOfContingentLiabilities>
