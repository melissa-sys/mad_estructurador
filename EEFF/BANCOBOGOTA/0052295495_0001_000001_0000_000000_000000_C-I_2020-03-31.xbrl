  <ifrs:ExplanationOfFinancialEffectOfNonadjustingEventAfterReportingPeriod contextRef="YQTD1C_NonadjustingEventsAfterReportingPeriodAxis_DisposalOfMajorSubsidiaryMember">No aplica</ifrs:ExplanationOfFinancialEffectOfNonadjustingEventAfterReportingPeriod>
