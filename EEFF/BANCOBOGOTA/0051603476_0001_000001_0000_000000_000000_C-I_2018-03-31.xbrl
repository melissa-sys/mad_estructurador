  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsNeitherPastDueNorImpairedMember" unitRef="COP" decimals="0">0</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsPastDueButNotImpairedMember" unitRef="COP" decimals="0">3771181878</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsIndividuallyAssessedForCreditLossesMember" unitRef="COP" decimals="0">11133506664</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsCollectivelyAssessedForCreditLossesMember" unitRef="COP" decimals="0">1464779809</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsImpairedMember" unitRef="COP" decimals="0">12598286473</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_EntitysTotalForImpairmentOfFinancialAssetsMember" unitRef="COP" decimals="0">16369468351</ifrs:FinancialAssets>
  <ifrs:AnalysisOfAgeOfFinancialAssetsThatArePastDueButNotImpaired contextRef="YQTD1C_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsNeitherPastDueNorImpairedMember">N/A</ifrs:AnalysisOfAgeOfFinancialAssetsThatArePastDueButNotImpaired>
