  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_NotLaterThanThreeMonthsMember" unitRef="COP" decimals="0">4976914938</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanThreeMonthsAndNotLaterThanSixMonthsMember" unitRef="COP" decimals="0">1144031216</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanSixMonthsAndNotLaterThanOneYearMember" unitRef="COP" decimals="0">2108026644</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanThreeMonthsAndNotLaterThanOneYearMember" unitRef="COP" decimals="0">3252057860</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanOneYearAndNotLaterThanThreeYearsMember" unitRef="COP" decimals="0">4314890765</ifrs:FinancialAssets>
