  <ifrs:EstimatedFinancialEffectOfContingentLiabilities contextRef="Q3ENDC_ClassesOfContingentLiabilitiesAxis_ShareOfContingentLiabilitiesOfAssociatesMember" unitRef="COP" decimals="0">0</ifrs:EstimatedFinancialEffectOfContingentLiabilities>
