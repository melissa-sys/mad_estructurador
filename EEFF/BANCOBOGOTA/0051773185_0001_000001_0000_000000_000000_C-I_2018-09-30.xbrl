  <ifrs:FinancialAssetsThatAreIndividuallyDeterminedToBeImpairedFairValueOfCollateralHeldAndOtherCreditEnhancements contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsImpairedMember" unitRef="COP" decimals="0">388912728</ifrs:FinancialAssetsThatAreIndividuallyDeterminedToBeImpairedFairValueOfCollateralHeldAndOtherCreditEnhancements>
