  <ifrs:FinancialAssets contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanThreeMonthsAndNotLaterThanOneYearMember" unitRef="COP" decimals="0">4019859942</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanOneYearAndNotLaterThanThreeYearsMember" unitRef="COP" decimals="0">4467832017</ifrs:FinancialAssets>
