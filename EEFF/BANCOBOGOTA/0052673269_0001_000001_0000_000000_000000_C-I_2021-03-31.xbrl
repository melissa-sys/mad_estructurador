  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsImpairedMember" unitRef="COP" decimals="0">7951030737</ifrs:FinancialAssets>
