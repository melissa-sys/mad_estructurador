  <ifrs:FinancialAssets contextRef="Q1ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsIndividuallyAssessedForCreditLossesMember" unitRef="COP" decimals="0">5411131270</ifrs:FinancialAssets>
