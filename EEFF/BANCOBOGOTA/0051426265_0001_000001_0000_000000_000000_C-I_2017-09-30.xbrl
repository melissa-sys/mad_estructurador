  <ifrs:FinancialAssetsThatAreIndividuallyDeterminedToBeImpairedFairValueOfCollateralHeldAndOtherCreditEnhancements contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosVencimientoEje_LaterThanFiveYearsMember" unitRef="COP" decimals="0">0</ifrs:FinancialAssetsThatAreIndividuallyDeterminedToBeImpairedFairValueOfCollateralHeldAndOtherCreditEnhancements>
