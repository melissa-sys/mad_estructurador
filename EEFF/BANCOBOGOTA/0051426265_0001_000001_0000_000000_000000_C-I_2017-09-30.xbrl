  <ifrs:FinancialAssets contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsPastDueButNotImpairedMember" unitRef="COP" decimals="0">3881162823</ifrs:FinancialAssets>
  <ifrs:FinancialAssets contextRef="Q3ENDC_InformacionRevelarActivosFinancierosMoraDeterioradosDeterioroEje_FinancialAssetsIndividuallyAssessedForCreditLossesMember" unitRef="COP" decimals="0">1024095327</ifrs:FinancialAssets>
