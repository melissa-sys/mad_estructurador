  <ifrs:EstimatedFinancialEffectOfContingentLiabilities contextRef="Q3ENDC_ClassesOfContingentLiabilitiesAxis_RestructuringContingentLiabilityMember" unitRef="COP" decimals="0">0</ifrs:EstimatedFinancialEffectOfContingentLiabilities>
