  <ifrs:EstimatedFinancialEffectOfContingentLiabilities contextRef="Q3ENDC_ClassesOfContingentLiabilitiesAxis_OtherEnvironmentRelatedContingentLiabilityMember" unitRef="COP" decimals="0">0</ifrs:EstimatedFinancialEffectOfContingentLiabilities>
  <ifrs:EstimatedFinancialEffectOfContingentLiabilities contextRef="Q3ENDC_ClassesOfContingentLiabilitiesAxis_TaxContingentLiabilityMember" unitRef="COP" decimals="0">0</ifrs:EstimatedFinancialEffectOfContingentLiabilities>
  <ifrs:EstimatedFinancialEffectOfContingentLiabilities contextRef="Q3ENDC_ClassesOfContingentLiabilitiesAxis_ContingentLiabilityForGuaranteesMember" unitRef="COP" decimals="0">24470780</ifrs:EstimatedFinancialEffectOfContingentLiabilities>
