  <ifrs:AnalysisOfAgeOfFinancialAssetsThatArePastDueButNotImpaired contextRef="YQTD2C_InformacionRevelarActivosFinancierosMoraDeterioradosClaseEje_DerivativesMember">N/A</ifrs:AnalysisOfAgeOfFinancialAssetsThatArePastDueButNotImpaired>
