    </xbrli:scenario>
  </xbrli:context>
  <ifrs:DescriptionOfNatureOfObligationContingentLiabilities contextRef="c11908" xsi:nil="true"></ifrs:DescriptionOfNatureOfObligationContingentLiabilities>
