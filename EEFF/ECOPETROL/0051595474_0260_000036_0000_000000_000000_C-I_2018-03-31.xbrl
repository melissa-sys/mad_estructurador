  <xbrli:context id="c5525">
    <xbrli:entity>
      <xbrli:identifier scheme="http://www.superfinanciera.gov.co">036</xbrli:identifier>
    </xbrli:entity>
    <xbrli:period>
      <xbrli:startDate>2016-01-01</xbrli:startDate>
      <xbrli:endDate>2016-06-30</xbrli:endDate>
    </xbrli:period>
    <xbrli:scenario>
