    </xbrli:scenario>
  </xbrli:context>
  <ifrs:DescriptionOfNatureOfObligationContingentLiabilities contextRef="c11784">Detalla los principales litigios reconocidos en el estado de situación financiera, cuyas expectativas de pérdidas son de alta probabilidad y podrían implicar una salida de recursos.</ifrs:DescriptionOfNatureOfObligationContingentLiabilities>
  <xbrli:context id="c11785">
    <xbrli:entity>
      <xbrli:identifier scheme="http://www.superfinanciera.gov.co">036</xbrli:identifier>
    </xbrli:entity>
